{
   "content_scripts": [ {
      "all_frames": true,
      "js": [ "content.js" ],
      "css" : ["mStyles.css"],
      "matches": [ "<all_urls>" ]
   } ],
   "description": "Save a bookmark with any video",
   "permissions": ["bookmarks", "tabs", "storage"],
   "host_permissions": [ "<all_urls>" ],
   "manifest_version": 3,
   "name": "D!EMONIC | SaveAnyVideoBookmark",
   "version": "1.0.2",
   "background": {
      "service_worker": "background.js"
   },
   "icons": {
      "16": "icon/v1/16.png",
      "32": "icon/v1/32.png",
      "48": "icon/v1/48.png",
      "64": "icon/v1/64.png",
      "128": "icon/v1/128.png",
      "256": "icon/v1/256.png",
      "512": "icon/v1/512.png"
   },
   "action": {
      "default_icon": {
         "16": "icon/v1/16.png",
         "32": "icon/v1/32.png",
         "48": "icon/v1/48.png",
         "64": "icon/v1/64.png",
         "128": "icon/v1/128.png",
         "256": "icon/v1/256.png",
         "512": "icon/v1/512.png"
      }
   },
   "options_page": "options.html"
}
