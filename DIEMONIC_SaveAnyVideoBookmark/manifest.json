{
   "content_scripts": [ {
      "all_frames": true,
      "js": [ "content.js" ],
      "css" : ["mStyles.css"],
      "matches": [ "<all_urls>" ]
   } ],
   "description": "Save a bookmark with any video",
   "permissions": ["bookmarks", "tabs", "scripting", "storage"],
   "host_permissions": [ "<all_urls>" ],
   "key": "",
   "manifest_version": 3,
   "name": "D!EMONIC | SaveAnyVideoBookmark",
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.0.0",
   "background": {
      "service_worker": "background.js"
   },
   "icons": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",  
      "64": "icon.png",
      "128": "icon.png"
   },
   "action": {},
   "options_page": "options.html"
}
