{
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [
      {
         "all_frames": true,
         "css": [ "style.css" ],
         "js": [ "content.js" ],
         "matches": [ "https://steamdb.info/sub/*", "https://steamdb.info/app/*", "https://steamdb.info/bundle/*" ]
      },
      {
         "all_frames": true,
         "js": [ "universal.js" ],
         "matches": [ "<all_urls>" ],
         "run_at": "document_idle"
      }
   ],
   "description": "Custom currency converter",
   "host_permissions": [ "https://www.cbr.ru/*", "<all_urls>" ],
   "manifest_version": 3,
   "name": "D!EMONIC | Currency Converter",
   "options_page": "options.html",
   "version": "1.0.2",
   "permissions": [ "storage" ],
   "action": {
      "default_popup": "popup.html",
      "default_title": "Currency Converter"
   },
   "icons": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "64": "icon.png",
      "128": "icon.png"
   }
}
