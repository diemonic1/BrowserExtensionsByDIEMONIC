{
    "manifest_version": 3,
    "name": "__MSG_extName__",
    "description": "__MSG_extDescription__",
    "default_locale": "en",
    "version": "1.0.1",
    "permissions": [ "storage" ],
    "host_permissions": [
        "https://steamcommunity.com/notes/list*",
        "https://store.steampowered.com/wishlist/*"
    ],
    "content_scripts": [
        {
            "matches": [ "https://steamcommunity.com/notes/list*" ],
            "js": [ "modules/notesExtender.js" ],
            "run_at": "document_start"
        },
        {
            "matches": [ "https://store.steampowered.com/wishlist/*" ],
            "js": [ "modules/wishlistExtender.js" ],
            "css": [ "styles/wishlistExtender.css" ],
            "run_at": "document_start"
        }
    ],
    "options_ui": {
        "page": "options.html"
    },
    "icons": {
        "16": "icon/16.png",
        "32": "icon/32.png",
        "48": "icon/48.png",
        "64": "icon/64.png",
        "128": "icon/128.png",
        "256": "icon/256.png",
        "512": "icon/512.png"
    }
}
