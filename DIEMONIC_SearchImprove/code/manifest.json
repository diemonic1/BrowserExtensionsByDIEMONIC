{
   "content_scripts": [ {
      "all_frames": true,
      "js": [ "content.js" ],
      "css" : ["mStyles.css"],
      "matches": [ "https://yandex.ru/search/*", "https://yandex.ru/video/search?*", "https://duckduckgo.com/*", "https://www.bing.com/search?*", "https://www.google.com/search?*", "https://yandex.ru/images/search?*", "https://yandex.ru/search?*" ]
   } ],
   "description": "Improving search in Yandex and Google",
   "web_accessible_resources":[
      {
         "resources": [ "chat.png", "you.png" ],
         "matches": [ "<all_urls>" ]
      }
   ],
   "host_permissions": [ "https://yandex.ru", "https://duckduckgo.com", "https://www.bing.com", "https://www.google.com" ],
   "manifest_version": 3,
   "name": "D!EMONIC | SearchImprove",
   "version": "1.0.0",
"icons": {
   "16": "icon.png",
   "32": "icon.png",
   "48": "icon.png",  
   "64": "icon.png",
   "128": "icon.png"
 }
}
