{
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ 
      {
         "all_frames": true,
         "css": [ "style.css" ],
         "js": [ "content.js" ],
         "matches": ["https://steamdb.info/sub/*", "https://steamdb.info/app/*"]
      }
   ],
   "description": "Custom currency converter for SteamDB",
   "host_permissions": [ "https://www.cbr.ru/*" ],
   "key": "",
   "manifest_version": 3,
   "name": "D!EMONIC | Currency Converter On SteamDB",
   "version": "0.0.1",
   "permissions": ["storage"],
      "icons": {
         "16": "icon.png",
         "32": "icon.png",
         "48": "icon.png",  
         "64": "icon.png",
         "128": "icon.png"
      }
}
