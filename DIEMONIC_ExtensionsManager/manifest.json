{
    "manifest_version": 3,
    "name": "__MSG_name__",
    "description": "__MSG_description__",
    "version": "1.0.0",
    "default_locale": "en",
    "action": {
        "default_title": "__MSG_name__",
        "default_popup": "popup/index.html",
        "default_icon": {
            "16": "icon/logo.png",
            "32": "icon/logo.png",
            "48": "icon/logo.png",
            "128": "icon/logo.png",
            "300": "icon/logo.png"
        }
    },
   "key": "",
    "web_accessible_resources": [
        {
            "resources": [
                "assets/*"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "icons": {
        "16": "icon/logo.png",
        "32": "icon/logo.png",
        "48": "icon/logo.png",
        "128": "icon/logo.png",
        "300": "icon/logo.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "permissions": [
        "management",
        "storage",
        "unlimitedStorage",
        "downloads",
        "clipboardWrite"
    ],
    "host_permissions": [
        "https://clients2.google.com/*",
        "https://clients2.googleusercontent.com/*"
    ]
}
