{
   "content_scripts": [ 
      {
         "all_frames": true,
         "js": [ "content.js" ],
         "matches": ["<all_urls>"],
         "run_at": "document_start"
      },
      {
         "matches": [ "https://mail.yandex.ru/*"],
         "js": [ "jquery-3.5.1.min.js", "mail_ads.js"],
         "run_at": "document_end"
      }
   ],
   "description": "Custom ad blocker",
   "host_permissions": [ "<all_urls>" ],
   "manifest_version": 3,
   "name": "D!EMONIC | Ads Block",
   "version": "1.0.2",
   "options_ui": {
      "page": "options.html"
   },
   "permissions": ["storage"],
      "icons": {
         "16": "icon.png",
         "32": "icon.png",
         "48": "icon.png",  
         "64": "icon.png",
         "128": "icon.png"
      }
}
